---
import Blocks from "../components/Blocks.astro";
import CabinShell from "../layouts/CabinShell.astro";
import type { Block } from "../data/projects";

// "How I co-author with Claude" — a standalone page on the rail. Voiced around
// the operator's working mode (mode-c cartographer + systems-mechanism reader)
// with Claude as a coworker. Neutral register; honest about what stays a human
// decision. No internal paths/data.
const blocks: Block[] = [
  {
    label: "the operating mode",
    kind: "prose",
    items: [
      "I work as a **mode-c cartographer** and a systems-mechanism reader: map the universe of a problem before deciding, read a system by its mechanism rather than its domain surface, and build the part it's missing.",
      "Claude is the coworker who lets me run that mode at speed. It maps the breadth with me: surveying an option space, drafting the solution stack, running the gates. I hold the read of the mechanism, the taste, and the decision. The cartography and the architecture stay mine; the legwork is shared.",
      "In practice that means starting wide — cataloging the option space before committing — then narrowing to the mechanism a problem actually runs on and building the smallest instrument the work needs. The division is deliberate: it keeps the work fast without letting the decisions drift away from me, so I can hold a problem at two altitudes at once and still commit to a build.",
    ],
  },
  {
    label: "from problem to ship",
    kind: "layers",
    items: [
      "map — `/mapit` catalogs the option space before anything is built; I pick what to pursue.",
      "form the stack — scope the solution as layers; Claude drafts against a fixed structure and I review every fork.",
      "build — `/sendit` scaffolds the repo; the work is co-written, then read line by line.",
      "verify — independent agents try to refute the claims and find the leaks; the `/vetit` gate must come back CLEAR.",
      "ship — `/shipit` flips it public with the hardening; the gate authorizes the flip.",
    ],
  },
  {
    label: "what stays a human decision",
    kind: "list",
    items: [
      "**The read** — which mechanism a system actually runs on, and what it's missing.",
      "**The design forks** — surfaced for me to choose; Claude proposes, I decide.",
      "**The taste** — what is honest, what is over-claimed, and what ships.",
    ],
  },
  {
    label: "guardrails",
    kind: "list",
    items: [
      "**Verify-gated** — claims and drafts are checked by independent agents prompted to refute, not to confirm.",
      "**Proof-gated** — nothing is positioned until an artifact proves it; in-build work stays labeled in-build.",
      "**Sanitized before publish** — a denylist grep, a secret scan, and an adversarial panel run before anything goes public.",
      "**Honest by default** — neutral output, no flattery; a disagreement gets surfaced rather than smoothed over.",
    ],
  },
  {
    label: "how this site was built",
    kind: "prose",
    items: [
      "This site, the eight public repositories, and the case studies were built this way — mapped, drafted, adversarially verified, and shipped through the same governed pipeline.",
    ],
  },
];
---

<CabinShell
  title="How I work with Claude — Chris Youngblut"
  description="How I work — mode-c cartographer and systems-mechanism reader, with Claude as a coworker — and what stays a human decision."
  crumb="co-authoring"
  activeTrunk="coauthoring"
>
  <article class="wu cs">
    <h1 class="wu-title">How I work with Claude</h1>

    <Blocks blocks={blocks} class="pblocks cs-blocks" />
  </article>
</CabinShell>
