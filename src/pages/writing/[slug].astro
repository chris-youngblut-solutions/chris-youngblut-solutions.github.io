---
import { getCollection, render } from "astro:content";
import { getProject } from "../../data/projects";
import { caseStudyToProject } from "../../data/related";
import { caseStudyMechanisms } from "../../data/case-study-mechanisms";
import Blocks from "../../components/Blocks.astro";
import CabinShell from "../../layouts/CabinShell.astro";

export async function getStaticPaths() {
  const entries = await getCollection("caseStudies");
  return entries.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

// Cross-link up to the project umbrella this case study belongs to.
const project = caseStudyToProject[entry.id]
  ? getProject(caseStudyToProject[entry.id])
  : undefined;

// Case-study layout: lead with the problem, then the full detail (the markdown
// body), then open to the bigger picture ("where it generalizes"). The three
// middle summary blocks (solution stack / obstacles & nuance / mapping the
// universe) are folded into the detail — the full writeup already covers them.
const mech = caseStudyMechanisms[entry.id];
const mblocks = mech?.blocks ?? [];
const problemBlock = mblocks.find((b) => b.label === "the problem");
const generalizesBlock = mblocks.find((b) => b.label === "where it generalizes");
---

<CabinShell
  title={`${entry.data.title} — C. Youngblut`}
  description={entry.data.summary}
  crumb={`writing / ${entry.id}`}
  activeTrunk="writing"
>
  <article class="wu cs">
    <a class="wu-back" href="/writing">← writing</a>

    {
      project && (
        <a class="related-link related-up" href={`/projects/${project.slug}`}>
          ↑ part of {project.name}
        </a>
      )
    }

    <div class="wu-eyebrow">
      {entry.data.lenses.map((l) => <span class="chip">{l}</span>)}
      {
        entry.data.repo && (
          <a class="chip" data-kind="accent" href={entry.data.repo.url}>
            {entry.data.repo.name} ↗
          </a>
        )
      }
    </div>

    <h1 class="wu-title">{entry.data.title}</h1>

    {problemBlock && <Blocks blocks={[problemBlock]} class="pblocks cs-blocks" />}

    <div class:list={["cs-body", problemBlock && "cs-body-detail"]}>
      {problemBlock && <p class="pblock-label cs-detail-label">the detail</p>}
      <Content />
    </div>

    {generalizesBlock && <Blocks blocks={[generalizesBlock]} class="pblocks cs-blocks cs-blocks-close" />}
  </article>
</CabinShell>
