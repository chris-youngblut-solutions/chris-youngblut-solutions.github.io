---
import Blocks from "../components/Blocks.astro";
import CabinShell from "../layouts/CabinShell.astro";
import type { Block } from "../data/projects";

// The landing is a brochure of who I am and what I'm developing — the work is
// the frame, not a role label (role-facing material lives on /cv). Capability-
// only on the legal line (no client/matter); method-only on trust & safety.
const developing: Block[] = [
  {
    label: "developing now",
    kind: "layers",
    items: [
      "Spaces — a desktop platform that freezes and thaws whole workspaces; GNOME and Hyprland from a shared core, dogfooding on my own machines.",
      "SecondChair — self-hosted legal RAG, in production with a solo-attorney practice; fully local reasoning is staged next.",
      "opendbc-ag — an open agricultural CAN/ISOBUS protocol library, with sprayer retrofit work in the field behind it.",
      "the fleet — multi-GPU serving and local-inference tuning (gfx1150-bench) across machines I provision and run.",
      "agent & evaluation tooling — an eval harness, a single-file spec renderer, and knowledge-context packs, public.",
      "Cabin — the design system this site runs on: warm paper, one accent, day and night.",
    ],
  },
];

const throughlines: Block[] = [
  {
    label: "through-lines",
    kind: "layers",
    items: [
      "industrial automation — pneumatic and hydraulic systems with condition-based preventive maintenance; baseline-and-deviation diagnostics. The same signal-path decomposition carries into the protocol and field-diagnostic work (opendbc-ag, raven-viper).",
      "trust & safety at scale — queues, risk, and big-data systems; a root-cause-analysis program that keeps a live ML enforcement model measurably correct (method-only).",
      "AI infrastructure — multi-GPU serving (vLLM behind a hand-written router), local inference and GPU performance engineering (gfx1150-bench), across a tailnet-linked fleet I provision and run.",
      "legal AI — privilege-aware BGE-M3 hybrid retrieval for a solo-attorney practice over a Qdrant vector store and a Neo4j graph (Cypher), with document access enforced as a code-level gate.",
      "dev platform — a scoping-to-signed-release pipeline run as skills (mapit → shipit), an adversarial release-review panel, and agent + evaluation infrastructure.",
      "data & BI — a governed dbt + MetricFlow semantic layer whose human and agent (MCP) consumers read the same numbers; typed knowledge graphs over real corpora.",
      "interfaces — local hold-to-talk dictation (voicekb), the Cabin design system this site runs on, and Spaces, a configurable desktop platform.",
    ],
  },
];
---

<CabinShell
  title="Christopher Youngblut — building and running my own stack"
  description="Who I am and what I'm developing — AI infrastructure, tooling, and the systems around them, built and run on hardware I own."
  crumb="about"
  activeTrunk="about"
>
  <p class="cabin-eyebrow">who i am · what i'm building</p>
  <h1 class="display">Christopher Youngblut</h1>

  <div class="cs-body">
    <p>
      I read a system by how it works, not by what it's called — and build the tool it's
      missing. The work runs on hardware I own, independently as <strong>^Loop Solutions</strong>.
    </p>
    <p>
      Everything ships through gates: mapped, built, adversarially reviewed, then public.
      The keystroke that goes public is mine.
    </p>
    <p>
      The <a href="/projects">projects</a> are the capabilities. The
      <a href="/writing">writing</a> is the proof — neutral studies of systems that shipped.
    </p>
  </div>

  <Blocks blocks={developing} class="pblocks cs-blocks" />

  <Blocks blocks={throughlines} class="pblocks cs-blocks" />

  <div class="cs-body cs-body-detail">
    <section class="md-bubble">
      <h2>Contact</h2>
      <ul>
        <li><a href="mailto:christopheryoungblut@gmail.com">christopheryoungblut@gmail.com</a></li>
        <li>
          <a href="https://linkedin.com/in/chris-youngblut-solutions">linkedin.com/in/chris-youngblut-solutions</a>
        </li>
        <li><a href="https://github.com/chris-youngblut-solutions">github.com/chris-youngblut-solutions</a></li>
      </ul>
    </section>
  </div>
</CabinShell>
