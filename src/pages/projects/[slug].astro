---
import { getCollection } from "astro:content";
import { getProject, projects } from "../../data/projects";
import { projectToCaseStudies } from "../../data/related";
import Blocks from "../../components/Blocks.astro";
import CabinShell from "../../layouts/CabinShell.astro";

export function getStaticPaths() {
  return projects.map((p) => ({ params: { slug: p.slug } }));
}

const { slug } = Astro.params;
const p = getProject(slug as string);
if (!p) throw new Error(`No project for slug: ${slug}`);

const subs = p.subs
  ? [...p.subs].sort((a, b) => a.name.localeCompare(b.name, undefined, { sensitivity: "base" }))
  : [];

// Cross-link: the deep case studies that go with this umbrella (short → long).
const allCaseStudies = await getCollection("caseStudies");
const related = (projectToCaseStudies[p.slug] ?? [])
  .map((id) => allCaseStudies.find((c) => c.id === id))
  .filter((c) => c !== undefined);

const blocks = p.blocks ?? [];
---

<CabinShell
  title={`${p.name} — C. Youngblut`}
  description={p.what}
  crumb={`projects / ${p.slug}`}
  activeTrunk="projects"
>
  <article class="wu">
    <a class="wu-back" href="/projects">← projects</a>

    <div class="wu-eyebrow">
      {p.tag && <span class="chip" data-kind="accent">{p.tag}</span>}
    </div>

    <h1 class="wu-title">{p.name}</h1>
    <p class="wu-lead">{p.what}</p>

    {
      blocks.length > 0 ? (
        <Blocks blocks={blocks} />
      ) : (
        <>
          <div class="wu-body">{p.body.map((para) => <p>{para}</p>)}</div>
          {subs.length > 0 && (
            <section class="pieces">
              <p class="pieces-h">the pieces</p>
              {subs.map((s) => (
                <div class="piece">
                  <p class="piece-name">{s.name}</p>
                  <p class="piece-sum">{s.summary}</p>
                </div>
              ))}
            </section>
          )}
        </>
      )
    }

    {
      related.length > 0 && (
        <section class="related">
          <p class="pieces-h">related writing</p>
          {related.map((c) => (
            <a class="related-link" href={`/writing/${c.id}`}>
              {c.data.title} →
            </a>
          ))}
        </section>
      )
    }
  </article>
</CabinShell>
