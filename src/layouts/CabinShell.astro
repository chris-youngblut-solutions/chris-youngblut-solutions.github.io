---
import ThemeToggle from "../lib/cabin/ThemeToggle.tsx";
import Base from "./Base.astro";

interface Props {
  title?: string;
  description?: string;
  crumb?: string;
  activeTrunk?: string;
}
const { title, description, crumb = "home", activeTrunk = "about" } = Astro.props;

// Left-rail trunks. Each points at a real v1 section (no dangling anchors).
// About is the landing (/); alphabetized for display.
const trunks = [
  { id: "projects", name: "Projects", href: "/projects" },
  { id: "writing", name: "Writing", href: "/writing" },
  { id: "repos", name: "Repos", href: "/repos" },
  { id: "coauthoring", name: "Co-authoring", href: "/coauthoring" },
  { id: "about", name: "About", href: "/" },
  { id: "resume", name: "Résumé", href: "/cv" },
].sort((a, b) => a.name.localeCompare(b.name, undefined, { sensitivity: "base" }));
---

<Base title={title} description={description}>
  <div class="site-shell">
    <header class="site-strip cabin-nav">
      <button
        type="button"
        class="cabin-brand"
        id="rail-toggle"
        aria-controls="site-rail"
        aria-expanded="true"
        aria-label="Toggle menu"><span class="cabin-caret">^</span>youngblut</button>
      <span class="cabin-nav-divider"></span>
      <span class="cabin-crumb">{crumb}</span>
      <div class="cabin-nav-right">
        <span class="strip-status"><span class="dot" data-risk="ok"></span>8 public repos</span>
        <ThemeToggle client:idle />
      </div>
    </header>

    <nav class="site-rail cabin-side" id="site-rail" aria-label="Sections">
      {
        trunks.map((t) => (
          <a
            class:list={["cabin-side-item", { "is-on": t.id === activeTrunk }]}
            href={t.href}
          >
            <span class="cabin-side-dot" />
            <span class="cabin-side-name">{t.name}</span>
          </a>
        ))
      }
    </nav>

    <main class="site-main">
      <div class="site-main-inner">
        <slot />
      </div>
    </main>
  </div>

  {/* Rail collapse — hover-driven on pointer devices (brand opens; leaving
      brand+rail closes after a grace delay). Brand click stays as the
      keyboard/touch fallback. Bundled + CSP-hashed. */}
  <script>
    const btn = document.getElementById("rail-toggle");
    const rail = document.getElementById("site-rail");
    const root = document.documentElement;
    const hoverable = window.matchMedia("(hover: hover)").matches;
    let closeTimer: ReturnType<typeof setTimeout> | undefined;

    function set(state: "open" | "collapsed") {
      root.dataset.rail = state;
      btn?.setAttribute("aria-expanded", String(state === "open"));
    }
    function open() {
      clearTimeout(closeTimer);
      set("open");
    }
    function scheduleClose() {
      clearTimeout(closeTimer);
      closeTimer = setTimeout(() => set("collapsed"), 260);
    }

    btn?.setAttribute("aria-expanded", String(root.dataset.rail !== "collapsed"));
    if (hoverable) {
      for (const el of [btn, rail]) {
        el?.addEventListener("mouseenter", open);
        el?.addEventListener("mouseleave", scheduleClose);
      }
    }
    btn?.addEventListener("click", () => {
      clearTimeout(closeTimer);
      set(root.dataset.rail === "collapsed" ? "open" : "collapsed");
    });
  </script>
</Base>
